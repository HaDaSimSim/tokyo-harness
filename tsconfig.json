{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2023"],
		"types": ["node", "bun"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true
	},
	"include": ["extension/**/*.ts", "bin/**/*.ts", "docs/spikes/**/*.ts"]
}
